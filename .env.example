# Local dev with docker-compose Postgres:
DATABASE_URL=postgresql://venturekeep:venturekeep@localhost:5432/venturekeep

# Production (Neon serverless Postgres):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/venturekeep?sslmode=require

# Auth — REQUIRED in production (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
# VENTUREKEEP_SECRET_KEY=your-secret-key-here

# CORS — comma-separated origins (defaults to "*" for local dev)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
